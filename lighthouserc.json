{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start -- --port 3200",
      "url": [
        "http://localhost:3200/",
        "http://localhost:3200/about",
        "http://localhost:3200/projects",
        "http://localhost:3200/projects/scivenia-mubazar-cloud",
        "http://localhost:3200/blog/shipping-faster-with-fewer-mistakes",
        "http://localhost:3200/contact"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2", "redirects-http"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1800 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 200 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
