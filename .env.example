NEXT_PUBLIC_SITE_URL=https://bright8.dev

# For Resend test mode, set CONTACT_FROM_EMAIL=onboarding@resend.dev
# In test mode, CONTACT_TO_EMAIL must match the email on your Resend account.
# To send from your own address, verify a domain at https://resend.com/domains.
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=
RESEND_API_KEY=

# Sentry. Without DSNs, error reporting falls back to console.warn.
# DSN is safe to expose; AUTH_TOKEN is not (only set in CI / Vercel, never commit).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=bright8
SENTRY_PROJECT=bright8
SENTRY_AUTH_TOKEN=

# Optional: Upstash Redis for multi-instance rate limiting.
# Without these, the contact API falls back to a per-instance in-memory bucket.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
