NEXT_PUBLIC_SITE_URL=https://bright8.dev

CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=
RESEND_API_KEY=

# Optional: endpoint that receives Web Vitals beacons in production.
NEXT_PUBLIC_VITALS_ENDPOINT=

# Sentry. Without DSNs, error reporting falls back to console.warn.
# DSN is safe to expose; AUTH_TOKEN is not (only set in CI / Vercel, never commit).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=bright8
SENTRY_PROJECT=bright8
SENTRY_AUTH_TOKEN=

# Optional: Upstash Redis for multi-instance rate limiting.
# Without these, the contact API falls back to a per-instance in-memory bucket.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
